{
	"name": "backend",
	"scripts": {
		"dev": "tsx watch src/server.ts",
		"build": "tsup src",
		"start": "node dist/server.js",
		"test": "vitest run",
		"test:watch": "vitest",
		"studio": "npx prisma studio",
		"seed": "npx prisma db seed",
		"seed:prod": "tsx prisma/seed-prod.ts",
		"migrate": "npx prisma migrate dev",
		"database:up": "docker compose --profile dev up -d",
		"database:stop": "docker compose --profile dev stop",
		"database:down": "docker compose --profile dev down"
	},
	"dependencies": {
		"@clerk/backend": "^3.2.12",
		"@fastify/cors": "^11.2.0",
		"@fastify/jwt": "^10.0.0",
		"@fastify/swagger": "^9.7.0",
		"@fastify/swagger-ui": "^5.2.5",
		"@prisma/adapter-pg": "^7.6.0",
		"@prisma/client": "^7.6.0",
		"axios": "^1.15.0",
		"bcrypt": "^6.0.0",
		"date-fns": "^4.1.0",
		"dotenv": "^17.3.1",
		"fastify": "^5.8.5",
		"fastify-plugin": "^5.1.0",
		"fastify-raw-body": "^5.0.0",
		"fastify-type-provider-zod": "^6.1.0",
		"helmet": "^8.1.0",
		"jsonwebtoken": "^9.0.3",
		"nodemailer": "^8.0.5",
		"pg": "^8.20.0",
		"svix": "^1.89.0",
		"swagger-themes": "^1.4.3",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@prisma/debug": "^7.6.0",
		"@types/bcrypt": "^6.0.0",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/node": "^22.19.15",
		"@types/nodemailer": "^7.0.11",
		"@types/pg": "^8.20.0",
		"get-tsconfig": "^4.13.7",
		"prisma": "^7.6.0",
		"resolve-pkg-maps": "^1.0.0",
		"ts-node": "^10.9.2",
		"tsup": "^8.5.1",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vitest": "^4.1.2"
	}
}